{
  "name": "opentalon",
  "version": "0.1.0",
  "description": "Visual agent control frontend for OpenClaw + llama.cpp",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "npm run build && cd backend && node server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
